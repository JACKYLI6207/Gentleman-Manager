{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gentleman-Manager-v1.2.1",
  "version": "1.2.1",
  "identifier": "com.gentleman.manager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5005",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gentleman-Manager-v1.2.1",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "licenseFile": "../LICENSE",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": ["TradChinese"]
      }
    }
  }
}
