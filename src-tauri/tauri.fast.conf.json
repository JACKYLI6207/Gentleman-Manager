{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gentleman-Manager-v1.2",
  "version": "1.2.0",
  "identifier": "com.jackyli6207.gentleman-manager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5005",
    "beforeBuildCommand": "pnpm build:fe:fast",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gentleman-Manager-v1.2",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
